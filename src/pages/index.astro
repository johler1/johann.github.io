	<button
		aria-label="Back to Top"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
	>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="true"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M4.5 15.75l7.5-7.5 7.5 7.5"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
	</button>

	<script>
		const mainContent = document.querySelector("[data-main-content]");
		const sectionNavLinks = Array.from(
			document.querySelectorAll("[data-section-link]"),
		);
		const underlineClasses = [
			"underline",
			"decoration-4",
			"decoration-accent",
			"underline-offset-4",
		];
		const linkById = new Map(
			sectionNavLinks.map((link) => [link.dataset.target, link]),
		);
		let activeSectionId = null;

		const showMainContent = () => {
			if (!mainContent) {
				return;
			}

			mainContent.classList.remove("lg:hidden");
		};

		const setActiveLink = (link) => {
			sectionNavLinks.forEach((navLink) => {
				navLink.classList.remove(...underlineClasses);
			});

			if (link) {
				link.classList.add(...underlineClasses);
			}
		};

		const scrollToSection = (section) => {
			if (!section) {
				return;
			}

			section.scrollIntoView({ behavior: "smooth", block: "start" });
		};

		const updateActiveSection = (sectionId) => {
			if (!sectionId || activeSectionId === sectionId) {
				return;
			}

			const link = linkById.get(sectionId);

			if (!link) {
				return;
			}

			setActiveLink(link);
			activeSectionId = sectionId;
		};

		const createSectionObserver = () => {
			if (!("IntersectionObserver" in window)) {
				return null;
			}

			const observedSections = Array.from(linkById.keys())
				.map((sectionId) => document.getElementById(sectionId))
				.filter(Boolean);

			if (!observedSections.length) {
				return null;
			}

			const observer = new IntersectionObserver(
				(entries) => {
					const visibleEntries = entries
						.filter((entry) => entry.isIntersecting)
						.sort(
							(a, b) => b.intersectionRatio - a.intersectionRatio,
						);

					if (!visibleEntries.length) {
						return;
					}

					updateActiveSection(visibleEntries[0].target.id);
				},
				{
					rootMargin: "-40% 0px -50% 0px",
					threshold: [0.1, 0.3, 0.6, 0.9],
				},
			);

			observedSections.forEach((section) => observer.observe(section));

			return observer;
		};

		const sectionObserver = createSectionObserver();

		sectionNavLinks.forEach((link) => {
			link.addEventListener("click", (event) => {
				event.preventDefault();

				const targetId = link.dataset.target;
				const targetSection = document.getElementById(targetId);

				if (!targetSection) {
					return;
				}

				showMainContent();
				setActiveLink(link);
				activeSectionId = targetId;
				scrollToSection(targetSection);
				history.replaceState(null, "", `#${targetId}`);
			});
		});

		const hashId = window.location.hash.replace("#", "");

		if (hashId) {
			const initialLink = sectionNavLinks.find(
				(link) => link.dataset.target === hashId,
			);
			const initialSection = document.getElementById(hashId);

			if (initialLink && initialSection) {
				showMainContent();
				setActiveLink(initialLink);
				activeSectionId = hashId;
				scrollToSection(initialSection);
			}
		}

		window.addEventListener("beforeunload", () => {
			if (sectionObserver) {
				sectionObserver.disconnect();
			}
		});

		const toTopBtn = document.getElementById("to-top-btn");

		window.addEventListener("scroll", () => {
			if (window.scrollY > 300) {
				toTopBtn.setAttribute("data-show", "true");
			} else {
				toTopBtn.setAttribute("data-show", "false");
			}
		});

		toTopBtn.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		document.querySelectorAll(".toggle-abstract").forEach((button) => {
			button.addEventListener("click", () => {
				const content = button.nextElementSibling;
				const arrow = button.querySelector(".arrow-icon");

				content.classList.toggle("hidden");
				arrow.classList.toggle("rotate-90");
			});
		});
	</script>
</PageLayout>
