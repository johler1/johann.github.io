	<button
		aria-label="Back to Top"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
	>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="true"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M4.5 15.75l7.5-7.5 7.5 7.5"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
	</button>

	<script>
		const toTopBtn = document.getElementById("to-top-btn");

		window.addEventListener("scroll", () => {
			if (window.scrollY > 300) {
				toTopBtn.setAttribute("data-show", "true");
			} else {
				toTopBtn.setAttribute("data-show", "false");
			}
		});

		toTopBtn.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		// Section reveal on scroll
		const revealObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.remove("opacity-0", "translate-y-4");
						revealObserver.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.1 }
		);
		document.querySelectorAll("[data-reveal]").forEach((el) => revealObserver.observe(el));

		// JMP easter egg
		let jmpBuffer = "";
		document.addEventListener("keydown", (e) => {
			if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
			jmpBuffer += e.key.toLowerCase();
			if (jmpBuffer.length > 3) jmpBuffer = jmpBuffer.slice(-3);
			if (jmpBuffer === "jmp") {
				jmpBuffer = "";
				const firstPaper = document.querySelector("#WIP li:nth-child(2)");
				if (firstPaper) {
					firstPaper.scrollIntoView({ behavior: "smooth", block: "center" });
					firstPaper.style.position = "relative";
					const glow = document.createElement("div");
					glow.style.cssText = "position:absolute;inset:-30px -40px;border-radius:20px;pointer-events:none;z-index:-1;opacity:0;transition:opacity 1s ease;background:radial-gradient(ellipse at center, hsl(16deg 65% 42% / 0.22) 0%, hsl(16deg 65% 50% / 0.10) 40%, transparent 70%);";
					firstPaper.appendChild(glow);
					requestAnimationFrame(() => glow.style.opacity = "1");
					setTimeout(() => {
						glow.style.transition = "opacity 3s ease-out";
						glow.style.opacity = "0";
						setTimeout(() => glow.remove(), 3000);
					}, 2500);
				}
			}
		});

		// Keyboard shortcuts
		const sectionKeys = { "1": "WP", "2": "WIP", "3": "Teaching", "4": "Experiences", "5": "Presentations" };
		document.addEventListener("keydown", (e) => {
			if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
			const id = sectionKeys[e.key];
			if (id) {
				const el = document.getElementById(id);
				if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
			}
		});

		// Magnetic social icons
		document.querySelectorAll("[data-magnetic]").forEach((icon) => {
			icon.addEventListener("mousemove", (e) => {
				const rect = icon.getBoundingClientRect();
				const x = e.clientX - rect.left - rect.width / 2;
				const y = e.clientY - rect.top - rect.height / 2;
				icon.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
			});
			icon.addEventListener("mouseleave", () => {
				icon.style.transform = "translate(0, 0)";
				icon.style.transition = "transform 0.3s ease-out";
			});
			icon.addEventListener("mouseenter", () => {
				icon.style.transition = "none";
			});
		});

		// Shuffle presentations animation
		const shuffleEls = document.querySelectorAll("[data-shuffle]");
		let shuffling = false;
		const shuffleObserver = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting && !shuffling) {
					shuffling = true;
					shuffleEls.forEach((el) => {
						const text = el.textContent.trim();
						const hasPeriod = text.endsWith(".");
						const raw = hasPeriod ? text.slice(0, -1) : text;
						const items = raw.split("|").map((s) => s.trim());
						const final = [...items];
						let count = 0;
						const maxShuffles = 10;
						const interval = setInterval(() => {
							if (count >= maxShuffles) {
								el.textContent = final.join(" | ") + (hasPeriod ? "." : "");
								clearInterval(interval);
								return;
							}
							const shuffledItems = [...items].sort(() => Math.random() - 0.5);
							el.textContent = shuffledItems.join(" | ") + (hasPeriod ? "." : "");
							count++;
						}, 150);
					});
				}
				if (!entry.isIntersecting) {
					shuffling = false;
				}
			});
		}, { threshold: 0.2 });
		const presSection = document.getElementById("Presentations");
		if (presSection) shuffleObserver.observe(presSection);

		document.querySelectorAll(".toggle-abstract").forEach((button) => {
			button.addEventListener("click", () => {
				const content = button.nextElementSibling;
				const arrow = button.querySelector(".arrow-icon");

				arrow.classList.toggle("rotate-90");

				if (content.style.maxHeight) {
					content.style.maxHeight = null;
				} else {
					content.style.maxHeight = content.scrollHeight + "px";
				}
			});
		});

		// Escape easter egg — everything flies off
		let escActive = false;
		document.addEventListener("keydown", (e) => {
			if (e.key !== "Escape" || escActive) return;
			escActive = true;

			const pieces = [
				...document.querySelectorAll("aside, main section, footer"),
			];

			const directions = [
				{ x: -120, y: -80, rot: -25 },
				{ x: 130, y: -90, rot: 20 },
				{ x: -110, y: 100, rot: 15 },
				{ x: 140, y: 70, rot: -18 },
				{ x: -90, y: -120, rot: 30 },
				{ x: 100, y: 110, rot: -22 },
				{ x: -130, y: -60, rot: 12 },
				{ x: 120, y: -100, rot: -28 },
				{ x: -100, y: 90, rot: 20 },
			];

			pieces.forEach((el, i) => {
				const dir = directions[i % directions.length];
				const delay = i * 70;
				const duration = 0.8 + Math.random() * 0.3;
				const spin = dir.rot + (Math.random() - 0.5) * 360;
				el.style.transition = `transform ${duration}s cubic-bezier(0.3, 0, 0.7, 0.2) ${delay}ms, opacity 0.5s ease ${delay + 300}ms`;
				el.style.transform = `translate(${dir.x}vw, ${dir.y}vh) rotate(${spin}deg)`;
				el.style.opacity = "0";
			});

			// Also hide the scroll progress bar
			const bar = document.getElementById("scroll-progress");
			if (bar) {
				bar.style.transition = "opacity 0.5s ease";
				bar.style.opacity = "0";
			}
		});

		// Nose easter egg — misty cursor trail
		const portrait = document.getElementById("portrait-wrap");
		let trailActive = false;
		let trailPoints = [];
		const canvas = document.createElement("canvas");
		canvas.style.cssText = "position:fixed;inset:0;pointer-events:none;z-index:9998;";
		const ctx = canvas.getContext("2d");

		function resizeCanvas() {
			canvas.width = window.innerWidth;
			canvas.height = window.innerHeight;
		}

		if (portrait) {
			portrait.addEventListener("click", (e) => {
				const rect = portrait.querySelector("img").getBoundingClientRect();
				const x = (e.clientX - rect.left) / rect.width;
				const y = (e.clientY - rect.top) / rect.height;
				// Nose zone: roughly center of face
				if (x > 0.35 && x < 0.65 && y > 0.35 && y < 0.55) {
					trailActive = !trailActive;
					if (trailActive) {
						document.body.appendChild(canvas);
						resizeCanvas();
						window.addEventListener("resize", resizeCanvas);
						requestAnimationFrame(drawTrail);
					} else {
						// Fade out
						const fadeOut = () => {
							if (trailPoints.length > 0) {
								trailPoints = trailPoints.slice(1);
								drawFrame();
								requestAnimationFrame(fadeOut);
							} else {
								canvas.remove();
								window.removeEventListener("resize", resizeCanvas);
							}
						};
						fadeOut();
					}
				}
			});
		}

		document.addEventListener("mousemove", (e) => {
			if (!trailActive) return;
			trailPoints.push({ x: e.clientX, y: e.clientY, life: 1.0 });
			if (trailPoints.length > 30) trailPoints.shift();
		});

		function drawFrame() {
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			for (let i = 0; i < trailPoints.length; i++) {
				const p = trailPoints[i];
				const t = i / trailPoints.length;
				const size = 4 + t * 14;
				const alpha = t * t * 0.5;
				ctx.beginPath();
				ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
				const linkColor = getComputedStyle(document.documentElement).getPropertyValue('--theme-link').trim();
				ctx.fillStyle = `hsla(${linkColor} / ${alpha})`;
				ctx.filter = `blur(${(1 - t) * 6}px)`;
				ctx.fill();
			}
			ctx.filter = "none";
		}

		function drawTrail() {
			if (!trailActive) return;
			trailPoints = trailPoints.slice(-30);
			drawFrame();
			requestAnimationFrame(drawTrail);
		}
	</script>

