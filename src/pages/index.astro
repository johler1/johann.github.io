---
import PageLayout from "@/layouts/Base.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

const sectionLinks = [
	{ id: "Home", label: "About" },
	{ id: "WP", label: "Working Papers" },
	{ id: "WIP", label: "Work in Progress" },
	{ id: "Experiences", label: "Experiences" },
	{ id: "Presentations", label: "Presentations" },
];
const footerLinks = [
	{
		href: "https://scholar.google.com/citations?user=GDBDCOAAAAAJ&hl=en",
		label: "GoogleScholar",
	},
	{ href: "https://x.com/OhlerJohann", label: "Twitter" },
	{ href: "mailto:j.p.ohler@lse.ac.uk", label: "Email" },
];
---

<PageLayout meta={{ title: "Research" }}>
	<div
		class="flex flex-col gap-12 lg:flex-row lg:items-start lg:gap-0 xl:gap-0"
	>
		<aside
			aria-label="Page sections"
			class="flex flex-col pb-6 dark:border-zinc-600 lg:sticky lg:top-12 lg:h-[calc(100vh-6rem)] lg:max-w-[35%] lg:flex-none lg:basis-[35%] lg:overflow-hidden lg:border-b-0 lg:border-e lg:border-black lg:pb-12"
		>
			<div
				class="flex flex-col gap-3 border-b border-black dark:border-zinc-600 lg:px-8"
			>
				<a
					class="mb-6 block text-center font-display text-[2.8rem] font-bold leading-tight text-textColor no-underline transition hover:text-link lg:text-left lg:text-[2.3rem]"
					href="/"
				>
					<span class="block">Johann Ohler</span>
				</a>
			</div>
			<div
				class="mt-40 hidden flex-col gap-3 border-b border-black dark:border-zinc-600 lg:flex"
			>
				<nav
					class="flex flex-col text-[1.3rem] font-semibold uppercase tracking-wide"
				>
					{
						sectionLinks.map(({ id, label }) => (
							<a
								class="mb-3 rounded-full px-4 py-2 text-textColor transition hover:text-link focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-link"
								data-section-link
								data-target={id}
								href={`#${id}`}
							>
								{label}
							</a>
						))
					}
				</nav>
			</div>
			<div class="mt-auto hidden flex-col gap-3 lg:flex lg:px-8">
				<div class="flex items-end justify-between">
					<nav
						class="flex flex-col text-[1rem] font-semibold tracking-wide"
					>
						{
							footerLinks.map(({ href, label }) => (
								<a
									class="text-textColor no-underline transition hover:text-link"
									href={href}
									target="_blank"
									rel="noopener noreferrer"
								>
									{label}
								</a>
							))
						}
					</nav>
					<div class="text-[1.1rem]">
						<ThemeToggle />
					</div>
				</div>
			</div>
		</aside>

		<main
			class="flex-1 lg:hidden lg:max-w-[60%] lg:flex-none lg:basis-[60%]"
			data-main-content
		>
			<section
				class="flex scroll-mt-24 flex-col pt-12 lg:mt-[140px]"
				id="Home"
			>
				<div
					class="flex flex-col items-center gap-6 lg:flex-row lg:items-stretch"
				>
					<div
						class="mb-12 space-y-6 px-10 text-[1.4rem] leading-tight lg:flex-1 lg:pl-10"
					>
						<p>
							I am a PhD Student in the Economic History
							department at the LSE. My research interests lie in
							<span
								class="decoration-3 font-bold underline decoration-accent"
								>Economic History</span
							>,
							<span
								class="decoration-3 font-bold underline decoration-accent"
								>Population Economics</span
							>, and
							<span
								class="decoration-3 font-bold underline decoration-accent"
								>Political Economy</span
							>.
						</p>
						<p>
							I am a member of the
							<a
								class="cactus-link text-link hover:underline"
								href="https://www.lse.ac.uk/Economic-History/HED"
								target="_blank"
								rel="noopener noreferrer"
							>
								Historical Economic Demography
							</a>
							group, and am supervised by
							<a
								class="cactus-link text-link hover:underline"
								href="https://www.ericbschneider.com/"
								target="_blank"
								rel="noopener noreferrer"
							>
								Eric Schneider
							</a>
							and
							<a
								class="cactus-link text-link hover:underline"
								href="https://www.tomraster.com/"
								target="_blank"
								rel="noopener noreferrer"
							>
								Tom Raster
							</a>
							. I will be visiting UCLA Economics from Spring 2026.
						</p>
						<p>
							You can find my CV
							<a
								class="cactus-link font-bold text-link hover:underline"
								href="https://www.dropbox.com/scl/fi/ztlk7oyrptvgxp0ee0o8h/CV_Johann_Ohler.pdf?rlkey=u6ojvd4kihatugfrmisl6zpkm&st=64uwzjj5&dl=0"
								target="_blank"
								rel="noopener noreferrer"
							>
								here
							</a>
							. Email: <a
								href="mailto:j.p.ohler@lse.ac.uk"
								class="text-link">j.p.ohler@lse.ac.uk</a
							>
						</p>
					</div>
					<img
						alt="Portrait"
						class="mx-auto hidden h-auto max-h-[500px] w-2/5 min-w-[250px] rounded-none object-cover min-[1000px]:block min-[1000px]:w-1/5 lg:w-1/3"
						loading="lazy"
						src="/WEBSITE_MP.jpg"
					/>
				</div>
			</section>

			<section
				class="mb-20 flex scroll-mt-24 flex-col gap-6 border-t border-black px-10 pt-12 dark:border-zinc-600"
				id="WP"
			>
				<h1 class="text-center text-lg font-bold sm:text-left">
					Working Papers
				</h1>
				<ul class="space-y-15">
					<li>
						<!-- TITLE -->
						<a
							class="mt-10 block text-[1.6rem] leading-tight text-accent no-underline hover:font-extrabold hover:underline"
							href="https://www.dropbox.com/scl/fi/ppoqbblsjfymmzgdn799v/BBH_1010.pdf?rlkey=fsyarcj3aroxygzzohe5i0zlu&st=mzow07oa&dl=0"
							target="_blank"
							rel="noopener noreferrer"
						>
							<strong
								>Build Better Health: Evidence from Ireland on
								Housing Quality and Mortality</strong
							>
						</a>

						<!-- COAUTHORS -->
						<div class="mt-1 text-[1.2rem]">
							with
							<a
								class="cactus-link"
								href="https://alandebromhead.weebly.com/"
								target="_blank"
								rel="noopener noreferrer"
							>
								Alan de Bromhead (UCD)
							</a>,
							<a
								class="cactus-link"
								href="https://www.ronanlyons.com/"
								target="_blank"
								rel="noopener noreferrer"
							>
								Ronan Lyons (TCD)
							</a>
						</div>

						<!-- ABSTRACT TOGGLE -->
						<div class="ml-2 mt-1">
							<button
								type="button"
								class="toggle-abstract flex items-center font-sans text-[1.2rem] font-semibold hover:text-link focus:outline-none"
							>
								<span
									class="arrow-icon flex h-3 w-3 items-center justify-center transition-transform duration-500"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-3 w-3 text-link"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										stroke-width="6"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M9 5l7 7-7 7"></path>
									</svg>
								</span>
								<span class="ml-2">Abstract</span>
							</button>

							<div
								class="abstract-content hidden overflow-hidden transition-all duration-700"
							>
								<p class="mt-2 text-[1.2rem] sm:ml-8">
									Poor housing conditions remain a major
									global public health challenge but direct
									causal evidence on their health effects is
									limited. We examine a rare rural housing
									intervention: the large-scale construction
									of subsidized high-quality cottages in
									Ireland 1883-1919. Using annual
									district-level data on deaths by cause, age
									and sex, we estimate the program's impact
									using difference-in-differences and
									triple-difference designs. Districts that
									built more cottages experienced mortality
									reductions of up to one death per thousand,
									driven by fewer respiratory deaths. The
									results are consistent with reduced indoor
									air pollution through improved ventilation.
									Cost-benefit analysis shows the scheme was
									highly cost-effective.
								</p>
							</div>
						</div>

						<!-- PRESENTATIONS + LINKS (same line) -->
						<div class="mt-1 text-[1.2rem]">
							<span class="italic">Presentations:</span>
							LSE Demography Seminar, CEPR Applied Micro-Economic History
							Workshop, CEPR Public Health Interventions Workshop.
							<span class="ml-2 text-[1.2rem]">
								[
								<a
									class="cactus-link no-underline hover:underline"
									href="https://cepr.org/publications/dp20725"
									target="_blank"
									rel="noopener noreferrer"
								>
									CEPR DP
								</a>
								] [
								<a
									class="cactus-link no-underline hover:underline"
									href="https://www.lse.ac.uk/asset-library/WP386.pdf"
									target="_blank"
									rel="noopener noreferrer"
								>
									LSE WP
								</a>
								]
							</span>
						</div>
					</li>

					<li>
						<!-- TITLE -->
						<a
							class="mt-10 block text-[1.6rem] leading-tight text-accent no-underline hover:font-extrabold hover:underline"
							href="https://www.dropbox.com/scl/fi/ahlc1oja63ohg1ans7a3w/EGT_1401.pdf?rlkey=msmrq8b8zz8fqvjgi2bkwn2km&st=16smjurs&dl=0"
							target="_blank"
							rel="noopener noreferrer"
						>
							<strong
								>Selection and Evolutionary Growth in
								pre-Industrial Germany</strong
							>
						</a>

						<!-- COAUTHORS -->
						<!-- <div class="mt-1 text-[1.2rem]">
			with
			<a class="cactus-link" href="https://alandebromhead.weebly.com/" target="_blank" rel="noopener noreferrer">
				Alan de Bromhead (UCD)
			</a>,
			<a class="cactus-link" href="https://www.ronanlyons.com/" target="_blank" rel="noopener noreferrer">
				Ronan Lyons (TCD)
			</a>
			</div> -->

						<!-- ABSTRACT TOGGLE -->
						<div class="ml-2 mt-1">
							<button
								type="button"
								class="toggle-abstract flex items-center font-sans text-[1.2rem] font-semibold hover:text-link focus:outline-none"
							>
								<span
									class="arrow-icon flex h-3 w-3 items-center justify-center transition-transform duration-500"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-3 w-3 text-link"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										stroke-width="6"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M9 5l7 7-7 7"></path>
									</svg>
								</span>
								<span class="ml-2">Abstract</span>
							</button>

							<div
								class="abstract-content hidden overflow-hidden transition-all duration-700"
							>
								<p class="mt-2 text-[1.2rem] sm:ml-8">
									Evolutionary growth theory posits that
									natural selection set the stage for modern
									growth. I leverage micro-data from
									historical Germany to assess the viability
									of the selection mechanisms. I estimate
									fertility differentials and the
									inter-generational transmission of SES. High
									status couples, proxied by occupation, had
									1-2 additional children, and SES was
									strongly heritable. To explore whether these
									parameters induce selection, I simulate an
									overlapping generation model of fertility
									choice and status transmission. The German
									parameters do not enable Clark's (2007)
									survival of the richest, whereas Galor and
									Moav's(2002) selection on quality can arise
									if the returns to investing in child quality
									are sufficiently large. Monte Carlo
									simulations extend the analysis beyond
									Germany. Survival of the richest requires
									exceptionally high coefficients of
									transmission (~0.87), and selection on
									quality emerges whenever returns to quality
									investments translate into higher fertility.
									Both depend on the strong heritability of
									the growth-complementary traits.
								</p>
							</div>
						</div>

						<!-- PRESENTATIONS + LINKS (same line) -->
						<div class="mt-1 text-[1.2rem]">
							<span class="italic">Presentations:</span>
							South Denmark University.
							<span class="ml-2 text-[1.2rem]">
								<!-- [
				<a class="cactus-link no-underline hover:underline" href="https://cepr.org/publications/dp20725" target="_blank" rel="noopener noreferrer">
				CEPR DP
				</a>
				] -->
								[
								<a
									class="cactus-link no-underline hover:underline"
									href="https://www.lse.ac.uk/asset-library/Economic-History/WP-390.pdf"
									target="_blank"
									rel="noopener noreferrer"
								>
									LSE WP
								</a>
								]
							</span>
						</div>
					</li>

					<li>
						<!-- TITLE -->
						<a
							class="mt-10 block text-[1.6rem] leading-tight text-accent no-underline hover:font-extrabold hover:underline"
							href="https://www.dropbox.com/scl/fi/yp1rbztsqu7pfmlho69uz/WWI_ORG_0602.pdf?rlkey=xtknsep5vtzfrft73bbh1n2ba&st=ehsbhwjp&dl=0"
							target="_blank"
							rel="noopener noreferrer"
						>
							<strong
								>Regional Identity in Organisations: Vertical
								Alignment on the Western Front of WW1</strong
							>
						</a>

						<!-- COAUTHORS -->
						<div class="mt-1 text-[1.2rem]">
							with
							<a
								class="cactus-link"
								href="https://brufalo.github.io/"
								target="_blank"
								rel="noopener noreferrer"
							>
								Oliver Brufal (University of Groningen)
							</a>
						</div>

						<!-- ABSTRACT TOGGLE -->
						<div class="ml-2 mt-1">
							<button
								type="button"
								class="toggle-abstract flex items-center font-sans text-[1.2rem] font-semibold hover:text-link focus:outline-none"
							>
								<span
									class="arrow-icon flex h-3 w-3 items-center justify-center transition-transform duration-500"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-3 w-3 text-link"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										stroke-width="6"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M9 5l7 7-7 7"></path>
									</svg>
								</span>
								<span class="ml-2">Abstract</span>
							</button>

							<div
								class="abstract-content hidden overflow-hidden transition-all duration-700"
							>
								<p class="mt-2 text-[1.2rem] sm:ml-8">
									Soldiers in conscripted armies have low
									incentives to exert effort; the reward for
									doing so is small, and the potential cost
									(death) is incalculable. We investigate
									whether shared regional identity between
									soldiers and officers can alter the
									incentive problem. We test this hypothesis
									using data on all French WW1 fatalities. We
									use a data-driven approach to infer cultural
									regions from surnames. Soldiers and officers
									are considered aligned if they were born in
									the same region. We estimate the effect of
									losing alignment in a design-based
									difference-in-difference setup. Conditional
									on the regiment and battle, whether a dead
									officer was regionally connected is
									quasi-random. Within-regiment variation
									shows mortality declines among treated
									soldiers. The effect is concentrated among
									officers with distinctly regional names,
									that are non-migrants, supporting a
									behavioural mechanism. Our results suggest
									that shared identity with superiors
									incentivises agents to exert greater effort.
								</p>
							</div>
						</div>

						<!-- PRESENTATIONS + LINKS (same line) -->
						<div class="mt-1 text-[1.2rem]">
							<span class="italic">Presentations:</span>
							Cambridge EH Graduate Seminar, LSE SPEECH, University
							of Mannheim.
							<!-- <span class="ml-2 text-[1.2rem]">
								[
								<a
