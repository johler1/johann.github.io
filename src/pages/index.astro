									href="https://www.dropbox.com/scl/fi/yp1rbztsqu7pfmlho69uz/WWI_ORG_0602.pdf?rlkey=xtknsep5vtzfrft73bbh1n2ba&st=ehsbhwjp&dl=0"
									target="_blank"
									rel="noopener noreferrer"
								>
									PDF
								</a>
								]
							</span> -->
						</div>
					</li>
				</ul>
			</section>

			<section
